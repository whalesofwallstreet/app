# Server Configuration
PORT=8080

# Database Configuration
# Format: postgres://[user[:password]@][host][:port][/database]
DATABASE_URL=postgres://postgres:postgres@localhost:5432/wow_engine

# Request Signature Verification
# Hex-encoded 32-byte Ed25519 public key used to verify Ed25519 signatures on
# incoming requests (X-Signature + X-Timestamp headers). When set, every route
# except the public allowlist (/api/v1/health, /api/v1/quote) requires a valid
# signature over "{METHOD}\n{PATH}\n{UNIX_TIMESTAMP}\n{SHA256_HEX(body)}".
# Leave unset to DISABLE verification (local dev only) — a startup warning is logged.
# SIGNING_PUBLIC_KEY=

# Logging
RUST_LOG=info,wow_engine=debug,sqlx=debug
